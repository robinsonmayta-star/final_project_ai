# --- Configuración del Sistema de Clasificación ---

# Fuentes a procesar (True/False)
PROCESS_IMAGES=True
PROCESS_VIDEOS=True

# Procesar un archivo específico (Dejar vacío para procesar todo)
# Ejemplo: SPECIFIC_FILE=1.mp4
SPECIFIC_FILE=

# Parámetros de detección
MODEL_PATH=yolov8n.pt
WINDOW_SECONDS=10
CONFIDENCE_THRESHOLD=0.4

# Rutas de carpetas
RAW_IMAGES_DIR=data/raw/images
RAW_VIDEOS_DIR=data/raw/videos
STAGING_DIR=data/staging
